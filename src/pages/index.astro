---
import Layout from '@layouts/Layout.astro';
import Cta from '@components/Cta.astro';

const jsonLdWebsite = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Les écrans pas tout le temps',
  url: 'https://www.lesecranspastoutletemps.fr',
};

const jsonLdPerformingGroup = {
  '@context': 'https://schema.org',
  '@type': 'PerformingGroup',
  name: 'Les écrans pas tout le temps',
  description:
    'Compagnie de spectacle théâtral participatif sur les écrans pour les enfants de 6 à 12 ans.',
  url: 'https://www.lesecranspastoutletemps.fr',
  location: {
    '@type': 'Place',
    addressLocality: 'Marseille',
    addressCountry: 'FR',
  },
  member: [
    {
      '@type': 'Person',
      name: 'Béatrice Herrero',
      jobTitle: 'Autrice, direction artistique, comédienne',
    },
    {
      '@type': 'Person',
      name: 'Samy',
      jobTitle: 'Comédien',
    },
  ],
  contactPoint: {
    '@type': 'ContactPoint',
    telephone: '+33673158508',
    email: 'lesecranspastoutletemps@gmail.com',
    contactType: 'customer service',
  },
};

const testimonials = [
  {
    // À VALIDER : pas d'attribution nominative sur le site Wix actuel. Demander à Béatrice.
    quote: "Super pièce ! Simple et efficace ! Les élèves ont accroché et ont été réactifs ! Une belle occasion pour se questionner et interroger son rapport aux écrans !",
  },
  {
    quote: "Spectacle percutant très bien conçu et adapté à l’âge des enfants, et proche de la vie quotidienne des familles.",
  },
  {
    quote: "Artistes très professionnels. Pièce touchante et pertinente — en lien avec l’EMI & le projet Parcours Petits Explorateurs du Web avec la mairie de Marseille, en cours. Les élèves ont adoré et la maitresse aussi ! Merci.",
  },
  {
    quote: "Le message véhiculé par le spectacle a été jugé pertinent par la grande majorité des enseignants. Ils estiment que le spectacle a su sensibiliser efficacement à la problématique des écrans et susciter une réflexion sur leurs usages. Les élèves se sont montrés actifs et réactifs face aux situations rencontrées dans ces scénettes.",
  },
];
---

<Layout
  title="Les écrans pas tout le temps – Spectacle écrans pour enfants 6-12 ans"
  description="Spectacle participatif et humoristique sur les écrans pour les enfants de 6 à 12 ans. Intervention en école, médiathèque, centre social. Béatrice & Samy."
  jsonLd={[jsonLdWebsite, jsonLdPerformingGroup]}
>
  <!-- ============================================================
       1. HERO
       ============================================================ -->
  <section class="bg-white" aria-label="Présentation">
    <div
      class="max-w-6xl mx-auto px-4 sm:px-6 py-12 sm:py-20 flex flex-col md:flex-row items-center gap-10 md:gap-16"
    >
      <!-- Texte -->
      <div class="flex-1 text-center md:text-left">
        <p class="font-heading font-semibold text-sm uppercase tracking-widest text-accent mb-3">
          Béatrice &amp; Samy
        </p>
        <h1
          class="font-heading font-black text-4xl sm:text-5xl lg:text-6xl text-text-main leading-tight mb-4"
        >
          Les écrans<br />pas tout<br />le temps&nbsp;!
        </h1>
        <p class="font-body text-lg text-gray-600 mb-8 max-w-md mx-auto md:mx-0">
          Spectacle humoristique sur le thème (sérieux) des écrans — 30&nbsp;min de spectacle +
          30&nbsp;min de débat avec la participation active des élèves.
        </p>
        <Cta />
      </div>

      <!-- Image hero -->
      <div class="flex-1 w-full max-w-lg md:max-w-none">
        <img
          src="/images/hero-beatrice-enfants.jpg"
          alt="Béatrice et Samy en scène avec des enfants lors du spectacle Les écrans pas tout le temps"
          width="574"
          height="342"
          loading="eager"
          fetchpriority="high"
          class="w-full rounded-sm object-cover shadow-md"
        />
      </div>
    </div>
  </section>

  <!-- ============================================================
       2. PRÉSENTATION DES 2 SPECTACLES
       ============================================================ -->
  <section class="bg-gray-50 py-14 sm:py-20" aria-label="Les deux spectacles">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 text-center">
      <p class="font-heading font-semibold text-sm uppercase tracking-widest text-accent mb-3">
        Avec
      </p>
      <h2 class="font-heading font-black text-3xl sm:text-4xl text-text-main mb-6">
        2 spectacles participatifs
      </h2>
      <p class="font-body text-lg text-gray-600 max-w-2xl mx-auto mb-12">
        À destination des enfants de 6 à 9 ans et de 9 à 12 ans.
      </p>

      <div class="grid sm:grid-cols-2 gap-6 max-w-3xl mx-auto">
        <!-- Spectacle 6-9 ans -->
        <a
          href="/spectacle-6-9-ans"
          class="group block bg-white border-2 border-gray-100 hover:border-accent rounded-sm p-8 text-left transition-colors duration-200 focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-4"
        >
          <p
            class="font-heading font-black text-4xl text-accent mb-2 group-hover:scale-105 transition-transform duration-200 inline-block"
          >
            6–9
          </p>
          <p class="font-heading font-bold text-lg text-text-main mb-2">ans</p>
          <p class="font-body text-gray-600 text-sm">
            Spectacle adapté au cycle 2 — maternelles grande section, CP, CE1, CE2.
          </p>
          <p
            class="font-heading font-semibold text-xs uppercase tracking-wider text-accent mt-4 group-hover:underline"
          >
            En savoir plus →
          </p>
        </a>

        <!-- Spectacle 9-12 ans -->
        <a
          href="/spectacle-9-12-ans"
          class="group block bg-white border-2 border-gray-100 hover:border-accent rounded-sm p-8 text-left transition-colors duration-200 focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-4"
        >
          <p
            class="font-heading font-black text-4xl text-accent mb-2 group-hover:scale-105 transition-transform duration-200 inline-block"
          >
            9–12
          </p>
          <p class="font-heading font-bold text-lg text-text-main mb-2">ans</p>
          <p class="font-body text-gray-600 text-sm">
            Spectacle adapté au cycle 3 — CM1, CM2, et entrée en 6ème.
          </p>
          <p
            class="font-heading font-semibold text-xs uppercase tracking-wider text-accent mt-4 group-hover:underline"
          >
            En savoir plus →
          </p>
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       3. VIGNETTES ÉQUIPE
       ============================================================ -->
  <section class="bg-white py-14 sm:py-20" aria-label="L'équipe artistique">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 sm:gap-6">
        <!-- Béatrice -->
        <div class="text-center">
          <div class="aspect-square overflow-hidden rounded-sm bg-gray-100 mb-3">
            <img
              src="/images/portrait-beatrice.jpg"
              alt="Béatrice Herrero, autrice, direction artistique et comédienne"
              width="200"
              height="200"
              loading="lazy"
              class="w-full h-full object-cover"
            />
          </div>
          <p class="font-heading font-bold text-sm text-text-main">Béatrice</p>
          <p class="font-body text-xs text-gray-500 mt-0.5">Direction artistique · Comédienne</p>
        </div>

        <!-- Samy -->
        <div class="text-center">
          <div class="aspect-square overflow-hidden rounded-sm bg-gray-100 mb-3">
            <img
              src="/images/portrait-samy.jpg"
              alt="Samy, comédien"
              width="200"
              height="200"
              loading="lazy"
              class="w-full h-full object-cover"
            />
          </div>
          <p class="font-heading font-bold text-sm text-text-main">Samy</p>
          <p class="font-body text-xs text-gray-500 mt-0.5">Comédien</p>
        </div>

        <!-- En scène -->
        <div class="text-center">
          <div class="aspect-square overflow-hidden rounded-sm bg-gray-100 mb-3">
            <img
              src="/images/gallery-01.jpg"
              alt="Béatrice et Samy en scène face aux élèves pendant le spectacle"
              width="200"
              height="200"
              loading="lazy"
              class="w-full h-full object-cover"
            />
          </div>
          <p class="font-heading font-bold text-sm text-text-main">En scène</p>
          <p class="font-body text-xs text-gray-500 mt-0.5">Avec les élèves</p>
        </div>

        <!-- Sticker / déco -->
        <div class="text-center">
          <div class="aspect-square overflow-hidden rounded-sm bg-accent mb-3 flex items-center justify-center p-4">
            <img
              src="/images/sticker.png"
              alt="Sticker Les écrans pas tout le temps"
              width="120"
              height="120"
              loading="lazy"
              class="w-full h-full object-contain"
            />
          </div>
          <p class="font-heading font-bold text-sm text-text-main">Rap avec les élèves</p>
          <p class="font-body text-xs text-gray-500 mt-0.5">Participation active</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       4. DESCRIPTION DU SPECTACLE
       ============================================================ -->
  <section class="bg-text-main text-white py-14 sm:py-20" aria-label="Le spectacle">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="font-heading font-black text-3xl sm:text-4xl text-accent mb-6">
        Les écrans pas tout le temps&nbsp;!
      </h2>
      <p class="font-body text-lg text-gray-300 mb-4">
        Spectacle humoristique sur le thème (sérieux) des écrans
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 sm:gap-12 mt-8">
        <div class="text-center">
          <p class="font-heading font-black text-5xl text-accent">30</p>
          <p class="font-heading font-semibold text-sm uppercase tracking-wider text-gray-400 mt-1">
            min de spectacle
          </p>
        </div>
        <div
          class="hidden sm:block w-px h-16 bg-gray-700"
          aria-hidden="true"
        ></div>
        <div class="text-center">
          <p class="font-heading font-black text-5xl text-accent">30</p>
          <p class="font-heading font-semibold text-sm uppercase tracking-wider text-gray-400 mt-1">
            min de débat
          </p>
        </div>
      </div>
      <p class="font-body text-gray-400 mt-6">avec la participation active des élèves</p>
      <div class="mt-10">
        <Cta />
      </div>
    </div>
  </section>

  <!-- ============================================================
       5. GALERIE PHOTOS
       ============================================================ -->
  <section class="bg-white py-14 sm:py-20" aria-label="Galerie photos">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <h2 class="font-heading font-black text-2xl sm:text-3xl text-text-main text-center mb-8">
        Photos du spectacle
      </h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 sm:gap-4">
        {
          [
            {
              src: '/images/gallery-01.jpg',
              alt: 'Béatrice et Samy en scène pendant le spectacle Les écrans pas tout le temps',
            },
            {
              src: '/images/gallery-02.jpg',
              alt: 'Les élèves participent activement au débat après le spectacle',
            },
            {
              src: '/images/gallery-03.jpg',
              alt: 'Moment de jeu interactif entre les comédiens et les enfants',
            },
            {
              src: '/images/gallery-04.jpg',
              alt: "Scène humoristique sur l'usage des écrans en famille",
            },
            {
              src: '/images/gallery-05.jpg',
              alt: 'Béatrice en scène pendant le rap participatif avec les élèves',
            },
            {
              src: '/images/gallery-06.jpg',
              alt: 'Samy et les enfants lors du temps de débat collectif',
            },
          ].map(({ src, alt }) => (
            <div class="aspect-square overflow-hidden rounded-sm bg-gray-100">
              <img
                src={src}
                alt={alt}
                width="400"
                height="400"
                loading="lazy"
                class="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
              />
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ============================================================
       6. TÉMOIGNAGES
       ============================================================ -->
  <section class="bg-gray-50 py-14 sm:py-20" aria-label="Témoignages">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <h2 class="font-heading font-black text-2xl sm:text-3xl text-text-main text-center mb-10">
        Ils ont aimé
      </h2>
      <div class="grid sm:grid-cols-2 gap-6">
        {
          testimonials.map(({ quote }) => (
            <blockquote class="bg-white rounded-sm p-6 border-l-4 border-accent shadow-sm">
              <p class="font-body text-gray-700 leading-relaxed italic">&laquo;&nbsp;{quote}&nbsp;&raquo;</p>
              {/* À VALIDER : ajouter attribution (nom, école, ville) si Béatrice peut fournir */}
            </blockquote>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ============================================================
       7. MENTION BÉATRICE + PDF ACADÉMIE
       ============================================================ -->
  <section class="bg-white py-12" aria-label="Références">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <p class="font-body text-gray-700 mb-3">
        <strong class="font-heading font-bold text-text-main">Béatrice HERRERO</strong>, autrice et
        comédienne.
      </p>
      <p class="font-body text-gray-600 text-sm">
        <a
          href="/docs/retours-academie-aix-marseille.pdf"
          class="text-text-main underline underline-offset-4 decoration-accent hover:decoration-2 focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-4 rounded-sm transition-all duration-150"
          target="_blank"
          rel="noopener noreferrer"
        >
          Lire l'analyse
        </a>{' '}
        des retours du spectacle — Académie d'Aix-Marseille
      </p>
    </div>
  </section>

  <!-- ============================================================
       8. BLOC CONTACT
       ============================================================ -->
  <section class="bg-accent py-14 sm:py-20" aria-label="Contact">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="font-heading font-black text-3xl sm:text-4xl text-text-main mb-4">
        Contactez-nous
      </h2>
      <p class="font-heading font-semibold text-sm uppercase tracking-widest text-text-main mb-8">
        Marseille
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 sm:gap-8 mb-10">
        <a
          href="tel:+33673158508"
          class="font-heading font-bold text-lg text-text-main hover:underline focus-visible:outline-2 focus-visible:outline-text-main focus-visible:outline-offset-4 rounded-sm"
        >
          06 73 15 85 08
        </a>
        <span class="hidden sm:block text-text-main opacity-30" aria-hidden="true">|</span>
        <a
          href="mailto:lesecranspastoutletemps@gmail.com"
          class="font-body text-base text-text-main hover:underline focus-visible:outline-2 focus-visible:outline-text-main focus-visible:outline-offset-4 rounded-sm break-all"
        >
          lesecranspastoutletemps@gmail.com
        </a>
      </div>
      <Cta text="Faire une demande de réservation" href="/contact" variant="dark" />
    </div>
  </section>
</Layout>
