---
import Layout from '@layouts/Layout.astro';
import Cta from '@components/Cta.astro';

const jsonLdWebsite = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Les écrans pas tout le temps',
  url: 'https://www.lesecranspastoutletemps.fr',
};

const jsonLdPerformingGroup = {
  '@context': 'https://schema.org',
  '@type': 'PerformingGroup',
  name: 'Les écrans pas tout le temps',
  description: 'Compagnie de spectacle théâtral participatif sur les écrans pour les enfants de 6 à 12 ans.',
  url: 'https://www.lesecranspastoutletemps.fr',
  location: { '@type': 'Place', addressLocality: 'Marseille', addressCountry: 'FR' },
  member: [
    { '@type': 'Person', name: 'Béatrice Herrero', jobTitle: 'Autrice, direction artistique, comédienne' },
    { '@type': 'Person', name: 'Samy', jobTitle: 'Comédien' },
  ],
  contactPoint: {
    '@type': 'ContactPoint',
    telephone: '+33673158508',
    email: 'lesecranspastoutletemps@gmail.com',
    contactType: 'customer service',
  },
};

const galleryPhotos = [
  { src: '/images/gallery-01.jpg', alt: 'Béatrice et Samy en scène pendant le spectacle Les écrans pas tout le temps' },
  { src: '/images/gallery-02.jpg', alt: 'Les élèves participent activement au débat après le spectacle' },
  { src: '/images/gallery-03.jpg', alt: 'Moment de jeu interactif entre les comédiens et les enfants' },
  { src: '/images/gallery-04.jpg', alt: "Scène humoristique sur l'usage des écrans en famille" },
  { src: '/images/gallery-05.jpg', alt: 'Béatrice en scène pendant le rap participatif avec les élèves' },
  { src: '/images/gallery-06.jpg', alt: 'Samy et les enfants lors du temps de débat collectif' },
];

const testimonials = [
  "Super pièce ! Simple et efficace ! Les élèves ont accroché et ont été réactifs ! Une belle occasion pour se questionner et interroger son rapport aux écrans !",
  "Spectacle percutant très bien conçu et adapté à l'âge des enfants, et proche de la vie quotidienne des familles.",
  "Artistes très professionnels. Pièce touchante et pertinente — en lien avec l'EMI & le projet Parcours Petits Explorateurs du Web avec la mairie de Marseille. Les élèves ont adoré et la maitresse aussi ! Merci.",
  "Le message véhiculé par le spectacle a été jugé pertinent par la grande majorité des enseignants. Les élèves se sont montrés actifs et réactifs face aux situations rencontrées dans ces scénettes.",
];
---

<Layout
  title="Les écrans pas tout le temps – Spectacle écrans pour enfants 6-12 ans"
  description="Spectacle participatif et humoristique sur les écrans pour les enfants de 6 à 12 ans. Intervention en école, médiathèque, centre social. Béatrice & Samy."
  jsonLd={[jsonLdWebsite, jsonLdPerformingGroup]}
  preloadImage="/images/hero-illustration.png"
>

  <!-- ============================================================
       1. HERO — sombre + texture étoilée + accent jaune
       ============================================================ -->
  <section class="bg-text-main relative overflow-hidden py-16 sm:py-28" aria-label="Présentation">
    <!-- Texture étoilée subtile (screen sur fond sombre = points blancs discrets) -->
    <div
      class="absolute inset-0 pointer-events-none select-none"
      style="background-image:url('/images/deco-02.png'); background-size:cover; mix-blend-mode:screen; opacity:0.12;"
      aria-hidden="true"
    ></div>

    <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6 flex flex-col md:flex-row items-center gap-10 md:gap-20">
      <!-- Texte -->
      <div class="flex-1 text-center md:text-left">
        <p class="font-heading font-semibold text-xs uppercase tracking-[0.2em] text-accent mb-5">
          Béatrice &amp; Samy
        </p>
        <h1 class="font-heading font-black text-5xl sm:text-6xl lg:text-[5.5rem] text-white leading-[1.02] mb-7">
          Les écrans<br />
          <span class="text-accent">pas tout</span><br />
          le temps&nbsp;!
        </h1>
        <p class="font-body text-gray-400 text-base leading-relaxed mb-8 max-w-sm mx-auto md:mx-0">
          Spectacle humoristique sur les écrans pour les enfants —
          30&nbsp;min de spectacle + 30&nbsp;min de débat avec leur participation active.
        </p>
        <Cta />
      </div>

      <!-- Image avec décalage jaune -->
      <div class="flex-1 w-full max-w-lg relative flex-shrink-0">
        <div
          class="absolute inset-0 translate-x-4 translate-y-4 bg-accent rounded-sm"
          aria-hidden="true"
        ></div>
        <img
          src="/images/hero-illustration.png"
          alt="Illustration Les écrans pas tout le temps — personnages d'enfants entourés d'écrans"
          width="768"
          height="715"
          loading="eager"
          fetchpriority="high"
          class="relative w-full object-contain"
        />
      </div>
    </div>
  </section>

  <!-- ============================================================
       2. PRÉSENTATION — blanc, cartes bordées
       ============================================================ -->
  <section class="bg-white py-16 sm:py-24" aria-label="Les deux spectacles">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 text-center">
      <p class="font-heading font-semibold text-xs uppercase tracking-[0.2em] bg-accent text-text-main px-3 py-0.5 rounded-sm mb-3">Avec</p>
      <h2 class="font-heading font-black text-3xl sm:text-4xl text-text-main mb-4">
        2 spectacles participatifs
      </h2>
      <p class="font-body text-gray-500 max-w-lg mx-auto mb-14">
        À destination des enfants de 6 à 9 ans et de 9 à 12 ans.
      </p>

      <div class="grid sm:grid-cols-2 gap-5 max-w-2xl mx-auto">
        {[
          { href: '/spectacle-6-9-ans',  age: '6–9',  desc: 'Grande section, CP, CE1, CE2.' },
          { href: '/spectacle-9-12-ans', age: '9–12', desc: 'CM1, CM2 et entrée en 6ème.' },
        ].map(({ href, age, desc }) => (
          <a
            href={href}
            class="group block text-left p-8 bg-text-main border-t-4 border-accent rounded-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_16px_40px_rgba(248,231,28,0.25)] focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-4"
          >
            <p class="font-heading font-black text-7xl text-accent leading-none mb-1">{age}</p>
            <p class="font-heading font-bold text-lg text-white mb-3">ans</p>
            <p class="font-body text-sm text-gray-400 mb-6">{desc}</p>
            <p class="font-heading font-bold text-xs uppercase tracking-widest text-accent inline-flex items-center gap-2">
              En savoir plus
              <span class="transition-transform duration-200 group-hover:translate-x-1 inline-block">→</span>
            </p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================
       3. VIGNETTES ÉQUIPE — sombre compact
       ============================================================ -->
  <section class="bg-text-main relative overflow-hidden py-12 sm:py-16" aria-label="L'équipe artistique">
    <div class="absolute inset-0 pointer-events-none select-none" style="background-image:url('/images/deco-03.png'); background-size:cover; mix-blend-mode:screen; opacity:0.10;" aria-hidden="true"></div>
    <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 sm:gap-5 max-w-2xl mx-auto">
        {[
          { src: '/images/gallery-01.jpg',        name: 'Béatrice',   role: 'Direction artistique · Comédienne', alt: 'Béatrice Herrero animant le débat avec les élèves' },
          { src: '/images/portrait-beatrice.jpg', name: 'Samy',       role: 'Comédien',                          alt: 'Samy, comédien du spectacle Les écrans pas tout le temps' },
          { src: '/images/en-scene.jpg',          name: 'En scène',   role: 'Avec les élèves',                   alt: 'Béatrice et Samy en scène dans une salle de classe' },
          { src: '/images/sticker.png',           name: 'Le sticker', role: 'Les écrans pas tout le temps !',    alt: 'Sticker Les écrans pas tout le temps' },
        ].map(({ src, name, role, alt }) => (
          <div class="text-center">
            <div class="aspect-square overflow-hidden rounded-sm bg-gray-800 mb-3 ring-2 ring-transparent hover:ring-accent transition-all duration-200">
              <img src={src} alt={alt} width="200" height="200" loading="lazy" class="w-full h-full object-cover" />
            </div>
            <p class="font-heading font-bold text-sm text-white">{name}</p>
            <p class="font-body text-xs text-gray-500 mt-0.5">{role}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================
       4. DESCRIPTION — jaune vif, sans texture (lisible, fun)
       ============================================================ -->
  <section class="bg-accent py-16 sm:py-24" aria-label="Le spectacle">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="font-heading font-black text-3xl sm:text-4xl text-text-main mb-3">
        Les écrans pas tout le temps&nbsp;!
      </h2>
      <p class="font-body text-text-main opacity-60 mb-12">
        Spectacle humoristique sur le thème (sérieux) des écrans
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-6 sm:gap-0 mb-12">
        <div class="text-center sm:px-12">
          <p class="font-heading font-black text-[6rem] sm:text-[8rem] text-text-main leading-none">30</p>
          <p class="font-heading font-semibold text-xs uppercase tracking-[0.15em] text-text-main opacity-60 mt-1">
            min de spectacle
          </p>
        </div>
        <div class="text-text-main text-4xl font-thin hidden sm:block opacity-30 select-none" aria-hidden="true">+</div>
        <div class="sm:hidden font-heading font-black text-text-main text-3xl opacity-40" aria-hidden="true">+</div>
        <div class="text-center sm:px-12">
          <p class="font-heading font-black text-[6rem] sm:text-[8rem] text-text-main leading-none">30</p>
          <p class="font-heading font-semibold text-xs uppercase tracking-[0.15em] text-text-main opacity-60 mt-1">
            min de débat
          </p>
        </div>
      </div>

      <p class="font-body text-text-main opacity-50 mb-10 text-sm">
        avec la participation active des élèves
      </p>
      <Cta variant="dark" />
    </div>
  </section>

  <!-- ============================================================
       5. GALERIE — sombre, grille serrée
       ============================================================ -->
  <section class="bg-text-main relative overflow-hidden py-12 sm:py-16" aria-label="Galerie photos">
    <div class="absolute inset-0 pointer-events-none select-none" style="background-image:url('/images/deco-01.png'); background-size:cover; mix-blend-mode:screen; opacity:0.12;" aria-hidden="true"></div>
    <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6">
      <h2 class="font-heading font-black text-xl text-white mb-6 text-center">
        Photos du spectacle
      </h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-1.5">
        {galleryPhotos.map(({ src, alt }, i) => (
          <a href={`#photo-${i}`} class="aspect-square overflow-hidden bg-gray-800 block cursor-zoom-in">
            <img
              src={src}
              alt={alt}
              width="400"
              height="400"
              loading="lazy"
              class="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
            />
          </a>
        ))}
      </div>
      <!-- Lightbox overlays -->
      {galleryPhotos.map(({ src, alt }, i) => (
        <div id={`photo-${i}`} class="lightbox-target pointer-events-none fixed inset-0 z-50 flex items-center justify-center bg-[#1C1C1C]/95 opacity-0 transition-opacity duration-200 [&:target]:pointer-events-auto [&:target]:opacity-100">
          <a href="#" class="absolute inset-0" aria-label="Fermer"></a>
          <div class="relative max-w-[90vw] max-h-[90vh] p-4">
            <img src={src} alt={alt} class="max-w-full max-h-[85vh] object-contain" />
            <a href="#" class="absolute top-2 right-2 w-10 h-10 flex items-center justify-center bg-accent text-text-main font-black text-xl rounded-sm hover:opacity-90 transition-opacity" aria-label="Fermer la galerie">&times;</a>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ============================================================
       6. TÉMOIGNAGES — blanc, bulles jaunes style BD
       ============================================================ -->
  <section class="bg-white py-16 sm:py-24" aria-label="Témoignages">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-12">
        <h2 class="font-heading font-black text-3xl sm:text-4xl text-text-main inline-block relative">
          Ils ont aimé
          <span class="absolute -bottom-1.5 left-0 right-0 h-2 bg-accent" aria-hidden="true"></span>
        </h2>
        <!-- À VALIDER : pas d'attribution nominative sur le site Wix actuel. Demander à Béatrice. -->
      </div>

      <div class="grid sm:grid-cols-2 gap-8 sm:gap-10">
        {testimonials.map((quote) => (
          <blockquote class="speech-bubble">
            <p class="font-body text-sm leading-relaxed italic text-text-main">
              &laquo;&nbsp;{quote}&nbsp;&raquo;
            </p>
          </blockquote>
        ))}
      </div>
    </div>

    <!-- Mention Béatrice + PDF (intégrée à la section blanche) -->
    <div class="max-w-6xl mx-auto px-4 sm:px-6 mt-14 pt-10 border-t border-gray-100 text-center">
      <p class="font-body text-gray-600 text-sm">
        <strong class="font-heading font-bold text-text-main">Béatrice HERRERO</strong>, autrice et
        comédienne.{' '}
        <a
          href="/docs/retours-academie-aix-marseille.pdf"
          class="underline underline-offset-4 decoration-accent hover:decoration-2 text-text-main focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-4 rounded-sm transition-all"
          target="_blank"
          rel="noopener noreferrer"
        >
          Lire l'analyse des retours du spectacle — Académie d'Aix-Marseille
        </a>
      </p>
    </div>
  </section>

  <!-- ============================================================
       7. CONTACT — sombre + texture étoilée (symétrie avec le hero)
       ============================================================ -->
  <section class="bg-text-main relative overflow-hidden py-16 sm:py-24" aria-label="Contact">
    <div
      class="absolute inset-0 pointer-events-none select-none"
      style="background-image:url('/images/deco-02.png'); background-size:cover; mix-blend-mode:screen; opacity:0.12;"
      aria-hidden="true"
    ></div>

    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="font-heading font-black text-3xl sm:text-4xl text-white mb-2">
        Contactez-nous
      </h2>
      <p class="font-heading font-semibold text-xs uppercase tracking-[0.2em] text-accent mb-8">
        Marseille
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 sm:gap-8 mb-10">
        {[
          { step: '1', title: 'Vous nous contactez', desc: "Formulaire ou téléphone" },
          { step: '2', title: 'Devis sous 48h', desc: "Personnalisé à votre structure" },
          { step: '3', title: 'On vient chez vous', desc: "Marseille et région PACA" },
        ].map(({ step, title, desc }) => (
          <div class="flex flex-col items-center text-center gap-1 max-w-[160px]">
            <span class="font-heading font-black text-3xl text-accent leading-none" aria-hidden="true">{step}</span>
            <p class="font-heading font-bold text-sm text-white">{title}</p>
            <p class="font-body text-xs text-gray-500">{desc}</p>
          </div>
        ))}
      </div>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-3 sm:gap-10 mb-10">
        <a
          href="tel:+33673158508"
          class="font-heading font-bold text-xl text-white hover:text-accent transition-colors duration-200 focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-4 rounded-sm"
        >
          06 73 15 85 08
        </a>
        <span class="hidden sm:block text-gray-700 text-2xl select-none" aria-hidden="true">·</span>
        <a
          href="mailto:lesecranspastoutletemps@gmail.com"
          class="font-body text-sm text-gray-400 hover:text-accent transition-colors duration-200 focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-4 rounded-sm break-all"
        >
          lesecranspastoutletemps@gmail.com
        </a>
      </div>

      <Cta text="Faire une demande de réservation" href="/contact" />
    </div>
  </section>

</Layout>

<style>
  .lightbox-target {
    scroll-behavior: smooth;
  }

  /* Bulle de BD : jaune avec ombre portée noire + queue pointue */
  .speech-bubble {
    background: #F8E71C;
    border-radius: 1.25rem;
    padding: 1.5rem 1.75rem 2rem;
    position: relative;
    box-shadow: 5px 5px 0 0 #1C1C1C;
  }

  .speech-bubble::after {
    content: '';
    position: absolute;
    bottom: -1.25rem;
    left: 2rem;
    border: 1.25rem solid transparent;
    border-top-color: #F8E71C;
    /* Ombre portée sur la queue */
    filter: drop-shadow(4px 3px 0 #1C1C1C);
  }
</style>
