---
import Layout from '@layouts/Layout.astro';
import Cta from '@components/Cta.astro';

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'PerformingGroup',
    name: 'Les écrans pas tout le temps',
    url: 'https://www.lesecranspastoutletemps.fr',
    location: { '@type': 'Place', addressLocality: 'Marseille', addressCountry: 'FR' },
    member: [
      { '@type': 'Person', name: 'Béatrice Herrero', jobTitle: 'Autrice, direction artistique, comédienne' },
      { '@type': 'Person', name: 'Samy', jobTitle: 'Comédien' },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Accueil', item: 'https://www.lesecranspastoutletemps.fr/' },
      { '@type': 'ListItem', position: 2, name: 'À propos', item: 'https://www.lesecranspastoutletemps.fr/a-propos/' },
    ],
  },
];

---

<Layout
  title="Béatrice & Samy – La compagnie derrière Les écrans pas tout le temps"
  description="Béatrice et Samy, le duo de théâtre à l'origine du spectacle participatif sur les écrans."
  jsonLd={jsonLd}
>

  <!-- HERO -->
  <section class="bg-text-main relative overflow-hidden py-14 sm:py-20" aria-label="Béatrice et Samy">
    <div class="absolute inset-0 pointer-events-none select-none" style="background-image:url('/images/deco-03.webp'); background-size:cover; mix-blend-mode:screen; opacity:0.10;" aria-hidden="true"></div>
    <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6">
      <nav aria-label="Fil d'Ariane" class="mb-8">
        <ol class="flex items-center gap-2 text-xs font-heading text-gray-500 list-none">
          <li><a href="/" class="hover:text-accent transition-colors">Accueil</a></li>
          <li class="text-gray-700" aria-hidden="true">›</li>
          <li class="text-accent" aria-current="page">À propos</li>
        </ol>
      </nav>
      <p class="font-heading font-semibold text-xs uppercase tracking-[0.2em] text-accent mb-4">Le duo</p>
      <h1 class="font-heading font-black text-4xl sm:text-5xl text-white leading-tight mb-6">
        Béatrice &amp; Samy
      </h1>
      <p class="font-body text-gray-400 text-base max-w-md">
        La compagnie derrière « Les écrans pas tout le temps ! » — basée à Marseille.
      </p>
    </div>
  </section>

  <!-- BÉATRICE -->
  <section class="bg-white py-14 sm:py-20">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 grid md:grid-cols-[280px_1fr] gap-10 md:gap-16 items-start">
      <div>
        <div class="aspect-square overflow-hidden rounded-sm bg-gray-100 mb-4 ring-4 ring-accent ring-offset-4 ring-offset-white">
          <img
            src="/images/gallery-01.jpg"
            alt="Béatrice Herrero, autrice, direction artistique et comédienne"
            width="280"
            height="280"
            loading="lazy"
            class="w-full h-full object-cover"
          />
        </div>
        <p class="font-heading font-black text-lg text-text-main">Béatrice Herrero</p>
        <p class="font-body text-xs text-gray-500 mt-0.5">Autrice · Direction artistique · Comédienne</p>
      </div>
      <div>
        <h2 class="font-heading font-black text-2xl text-text-main mb-5">Béatrice</h2>
        <!-- CONTENU À VALIDER : bio complète à fournir par Béatrice -->
        <div class="font-body text-gray-600 leading-relaxed space-y-4">
          <p>
            Béatrice Herrero est l'autrice et la comédienne à l'origine du projet « Les écrans
            pas tout le temps ! ». Comédienne de formation, elle a conçu ce spectacle à partir
            d'un constat simple : les enfants d'aujourd'hui grandissent entourés d'écrans, souvent
            sans recul ni espace de parole pour en discuter.
          </p>
          <p>
            Son écriture mêle humour et questionnements sérieux, pour créer un théâtre qui parle
            vraiment aux enfants — et qui leur donne les outils pour penser par eux-mêmes.
          </p>
          <!-- CONTENU MANQUANT : biographie complète de Béatrice à compléter -->
        </div>
      </div>
    </div>
  </section>

  <!-- SAMY -->
  <section class="bg-gray-50 py-14 sm:py-20">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 grid md:grid-cols-[1fr_280px] gap-10 md:gap-16 items-start">
      <div class="md:order-1">
        <h2 class="font-heading font-black text-2xl text-text-main mb-5">Samy</h2>
        <!-- CONTENU À VALIDER : bio complète à fournir -->
        <div class="font-body text-gray-600 leading-relaxed space-y-4">
          <p>
            Samy est le comédien complice de Béatrice sur scène. Ensemble, ils forment un duo
            complémentaire qui sait tenir une salle d'élèves en haleine, entre éclats de rire et
            moments de réflexion.
          </p>
          <p>
            Sa présence scénique et son sens du rythme font du temps de débat un vrai moment
            d'échange — jamais un cours, toujours une conversation.
          </p>
          <!-- CONTENU MANQUANT : biographie complète de Samy à compléter -->
        </div>
      </div>
      <div class="md:order-2">
        <div class="aspect-square overflow-hidden rounded-sm bg-gray-200 mb-4 ring-4 ring-accent ring-offset-4 ring-offset-gray-50">
          <img
            src="/images/portrait-beatrice.jpg"
            alt="Samy, comédien"
            width="280"
            height="280"
            loading="lazy"
            class="w-full h-full object-cover"
          />
        </div>
        <p class="font-heading font-black text-lg text-text-main">Samy</p>
        <p class="font-body text-xs text-gray-500 mt-0.5">Comédien</p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-accent py-14 sm:py-16 text-center">
    <div class="max-w-2xl mx-auto px-4 sm:px-6">
      <h2 class="font-heading font-black text-2xl text-text-main mb-3">Travailler avec Béatrice &amp; Samy</h2>
      <p class="font-body text-text-main opacity-60 text-sm mb-8">Écoles, médiathèques, mairies, centres sociaux — contactez-nous.</p>
      <Cta variant="dark" text="Nous contacter" href="/contact" />
    </div>
  </section>

</Layout>
