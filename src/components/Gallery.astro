---
interface Props {
  photos: { src: string; alt: string }[];
  count?: number;
}
const { photos } = Astro.props;
---

<div class="gallery-grid" id="gallery-grid">
  {photos.map((photo, i) => (
    <button
      class="gallery-item"
      data-index={i}
      aria-label={`Voir en grand : ${photo.alt}`}
      type="button"
    >
      <img
        src={photo.src}
        alt={photo.alt}
        loading="lazy"
        decoding="async"
        class="gallery-thumb"
      />
      <span class="gallery-hover-ring" aria-hidden="true"></span>
      <span class="gallery-zoom" aria-hidden="true">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
          <circle cx="7.5" cy="7.5" r="5.5" stroke="currentColor" stroke-width="1.75"/>
          <path d="M11.5 11.5L16 16" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
          <path d="M5.5 7.5h4M7.5 5.5v4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </span>
    </button>
  ))}
</div>

<!-- Modale lightbox -->
<div
  id="gallery-modal"
  role="dialog"
  aria-modal="true"
  aria-label="Galerie photos"
  aria-hidden="true"
  class="gallery-modal"
>
  <div class="gallery-modal-overlay" id="gallery-overlay"></div>
  <div class="gallery-modal-content">
    <button class="gallery-btn gallery-close" id="gallery-close" aria-label="Fermer la galerie" type="button">
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
        <path d="M2 2l14 14M16 2L2 16" stroke="currentColor" stroke-width="2.25" stroke-linecap="round"/>
      </svg>
    </button>
    <button class="gallery-btn gallery-prev" id="gallery-prev" aria-label="Photo précédente" type="button">
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
        <path d="M12 2L4 9l8 7" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
    <div class="gallery-img-wrap">
      <img id="gallery-img" src="" alt="" class="gallery-modal-img" />
    </div>
    <button class="gallery-btn gallery-next" id="gallery-next" aria-label="Photo suivante" type="button">
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
        <path d="M6 2l8 7-8 7" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
    <p class="gallery-counter" id="gallery-counter" aria-live="polite"></p>
  </div>
</div>

<script>
  const photos: { src: string; alt: string }[] = Array.from(
    document.querySelectorAll<HTMLButtonElement>('#gallery-grid .gallery-item')
  ).map((btn) => ({
    src: btn.querySelector('img')!.src,
    alt: btn.querySelector('img')!.alt,
  }));

  const modal    = document.getElementById('gallery-modal')!;
  const overlay  = document.getElementById('gallery-overlay')!;
  const img      = document.getElementById('gallery-img') as HTMLImageElement;
  const counter  = document.getElementById('gallery-counter')!;
  const btnClose = document.getElementById('gallery-close')!;
  const btnPrev  = document.getElementById('gallery-prev')!;
  const btnNext  = document.getElementById('gallery-next')!;

  let current = 0;
  let lastFocus: HTMLElement | null = null;

  const focusable = (): HTMLElement[] =>
    Array.from(modal.querySelectorAll<HTMLElement>('button'));

  function show(index: number) {
    current = (index + photos.length) % photos.length;
    img.src = photos[current].src;
    img.alt = photos[current].alt;
    counter.textContent = `${current + 1} / ${photos.length}`;
  }

  function open(index: number) {
    lastFocus = document.activeElement as HTMLElement;
    show(index);
    modal.setAttribute('aria-hidden', 'false');
    modal.classList.add('is-open');
    document.body.style.overflow = 'hidden';
    btnClose.focus();
  }

  function close() {
    modal.setAttribute('aria-hidden', 'true');
    modal.classList.remove('is-open');
    document.body.style.overflow = '';
    lastFocus?.focus();
  }

  document.querySelectorAll<HTMLButtonElement>('#gallery-grid .gallery-item').forEach((btn, i) => {
    btn.addEventListener('click', () => open(i));
  });

  btnClose.addEventListener('click', close);
  overlay.addEventListener('click', close);
  btnPrev.addEventListener('click', () => show(current - 1));
  btnNext.addEventListener('click', () => show(current + 1));

  document.addEventListener('keydown', (e) => {
    if (!modal.classList.contains('is-open')) return;
    if (e.key === 'Escape')      { close(); return; }
    if (e.key === 'ArrowLeft')   { show(current - 1); return; }
    if (e.key === 'ArrowRight')  { show(current + 1); return; }
    if (e.key === 'Tab') {
      const els = focusable();
      const first = els[0], last = els[els.length - 1];
      if (e.shiftKey) {
        if (document.activeElement === first) { e.preventDefault(); last.focus(); }
      } else {
        if (document.activeElement === last)  { e.preventDefault(); first.focus(); }
      }
    }
  });
</script>

<style>
  /* ── Grid ─────────────────────────────────────────── */
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 3px;
    background: #111;
  }
  @media (min-width: 768px)  { .gallery-grid { grid-template-columns: repeat(4, 1fr); } }
  @media (min-width: 1024px) { .gallery-grid { grid-template-columns: repeat(5, 1fr); } }
  @media (min-width: 1280px) { .gallery-grid { grid-template-columns: repeat(6, 1fr); } }

  /* ── Thumbnail ──────────────────────────────────────── */
  .gallery-item {
    display: block;
    aspect-ratio: 3 / 2;
    padding: 0;
    border: none;
    background: #1a1a1a;
    cursor: zoom-in;
    overflow: hidden;
    position: relative;
  }

  .gallery-thumb {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease, filter 0.3s ease;
    filter: brightness(0.96);
  }

  /* Yellow ring overlay */
  .gallery-hover-ring {
    position: absolute;
    inset: 0;
    box-shadow: inset 0 0 0 0px #F8E71C;
    transition: box-shadow 0.2s ease;
    pointer-events: none;
    z-index: 1;
  }

  /* Zoom icon */
  .gallery-zoom {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #F8E71C;
    opacity: 0;
    transition: opacity 0.2s ease;
    z-index: 2;
    pointer-events: none;
  }
  .gallery-zoom svg {
    filter: drop-shadow(0 1px 4px rgba(0,0,0,0.8));
  }

  /* Hover state */
  .gallery-item:hover .gallery-thumb,
  .gallery-item:focus-visible .gallery-thumb {
    transform: scale(1.06);
    filter: brightness(0.55);
  }
  .gallery-item:hover .gallery-hover-ring,
  .gallery-item:focus-visible .gallery-hover-ring {
    box-shadow: inset 0 0 0 3px #F8E71C;
  }
  .gallery-item:hover .gallery-zoom,
  .gallery-item:focus-visible .gallery-zoom {
    opacity: 1;
  }

  .gallery-item:focus-visible {
    outline: 3px solid #F8E71C;
    outline-offset: 1px;
  }

  /* ── Modal ──────────────────────────────────────────── */
  .gallery-modal {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 200;
    align-items: center;
    justify-content: center;
  }
  .gallery-modal.is-open { display: flex; }

  .gallery-modal-overlay {
    position: absolute;
    inset: 0;
    background: rgba(8, 8, 8, 0.95);
    backdrop-filter: blur(6px);
  }

  .gallery-modal-content {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    gap: 1rem;
    max-width: 95vw;
    max-height: 95vh;
  }

  .gallery-img-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .gallery-modal-img {
    max-width: min(84vw, 1200px);
    max-height: 87vh;
    object-fit: contain;
    box-shadow: 0 0 0 1px rgba(255,255,255,0.06), 0 32px 80px rgba(0,0,0,0.7);
  }

  /* ── Nav buttons ──────────────────────────────────── */
  .gallery-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 2px;
    border: 1.5px solid rgba(248,231,28,0.3);
    background: rgba(248,231,28,0.07);
    color: #F8E71C;
    cursor: pointer;
    flex-shrink: 0;
    transition: background 0.15s, border-color 0.15s;
  }
  .gallery-btn:hover {
    background: rgba(248,231,28,0.18);
    border-color: rgba(248,231,28,0.8);
  }
  .gallery-btn:focus-visible {
    outline: 2px solid #F8E71C;
    outline-offset: 2px;
  }

  .gallery-close {
    position: absolute;
    top: -3.75rem;
    right: 0;
    z-index: 2;
    border-color: rgba(255,255,255,0.2);
    color: rgba(255,255,255,0.7);
    background: rgba(255,255,255,0.06);
  }
  .gallery-close:hover {
    border-color: rgba(255,255,255,0.6);
    background: rgba(255,255,255,0.14);
    color: #fff;
  }

  @media (max-width: 639px) {
    .gallery-modal-content { gap: 0.5rem; }
    .gallery-btn { width: 2rem; height: 2rem; }
    .gallery-close { top: -2.75rem; }
  }

  /* ── Counter ─────────────────────────────────────── */
  .gallery-counter {
    position: absolute;
    bottom: -2.5rem;
    left: 50%;
    transform: translateX(-50%);
    color: rgba(255,255,255,0.35);
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    white-space: nowrap;
    font-variant-numeric: tabular-nums;
  }

  /* ── Reduced motion ──────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .gallery-thumb,
    .gallery-hover-ring,
    .gallery-zoom { transition: none; }
  }
</style>
