---
interface Props {
  photos: { src: string; alt: string }[];
}
const { photos } = Astro.props;
---

<div class="gallery-grid" id="gallery-grid">
  {photos.map((photo, i) => (
    <button
      class="gallery-item"
      data-index={i}
      aria-label={`Voir en grand : ${photo.alt}`}
      type="button"
    >
      <img
        src={photo.src}
        alt={photo.alt}
        loading="lazy"
        decoding="async"
        class="gallery-thumb"
      />
    </button>
  ))}
</div>

<!-- Modale lightbox -->
<div
  id="gallery-modal"
  role="dialog"
  aria-modal="true"
  aria-label="Galerie photos"
  aria-hidden="true"
  class="gallery-modal"
>
  <div class="gallery-modal-overlay" id="gallery-overlay"></div>
  <div class="gallery-modal-content">
    <button class="gallery-btn gallery-close" id="gallery-close" aria-label="Fermer la galerie" type="button">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
        <path d="M2 2l16 16M18 2L2 18" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
      </svg>
    </button>
    <button class="gallery-btn gallery-prev" id="gallery-prev" aria-label="Photo précédente" type="button">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
        <path d="M13 2L5 10l8 8" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
    <div class="gallery-img-wrap">
      <img id="gallery-img" src="" alt="" class="gallery-modal-img" />
    </div>
    <button class="gallery-btn gallery-next" id="gallery-next" aria-label="Photo suivante" type="button">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
        <path d="M7 2l8 8-8 8" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
    <p class="gallery-counter" id="gallery-counter" aria-live="polite"></p>
  </div>
</div>

<script>
  const photos: { src: string; alt: string }[] = Array.from(
    document.querySelectorAll<HTMLButtonElement>('#gallery-grid .gallery-item')
  ).map((btn) => ({
    src: btn.querySelector('img')!.src,
    alt: btn.querySelector('img')!.alt,
  }));

  const modal    = document.getElementById('gallery-modal')!;
  const overlay  = document.getElementById('gallery-overlay')!;
  const img      = document.getElementById('gallery-img') as HTMLImageElement;
  const counter  = document.getElementById('gallery-counter')!;
  const btnClose = document.getElementById('gallery-close')!;
  const btnPrev  = document.getElementById('gallery-prev')!;
  const btnNext  = document.getElementById('gallery-next')!;

  let current = 0;
  let lastFocus: HTMLElement | null = null;

  const focusable = (): HTMLElement[] =>
    Array.from(modal.querySelectorAll<HTMLElement>('button'));

  function show(index: number) {
    current = (index + photos.length) % photos.length;
    img.src = photos[current].src;
    img.alt = photos[current].alt;
    counter.textContent = `${current + 1} / ${photos.length}`;
  }

  function open(index: number) {
    lastFocus = document.activeElement as HTMLElement;
    show(index);
    modal.setAttribute('aria-hidden', 'false');
    modal.classList.add('is-open');
    document.body.style.overflow = 'hidden';
    btnClose.focus();
  }

  function close() {
    modal.setAttribute('aria-hidden', 'true');
    modal.classList.remove('is-open');
    document.body.style.overflow = '';
    lastFocus?.focus();
  }

  // Open on thumb click
  document.querySelectorAll<HTMLButtonElement>('#gallery-grid .gallery-item').forEach((btn, i) => {
    btn.addEventListener('click', () => open(i));
  });

  btnClose.addEventListener('click', close);
  overlay.addEventListener('click', close);
  btnPrev.addEventListener('click', () => show(current - 1));
  btnNext.addEventListener('click', () => show(current + 1));

  // Keyboard
  document.addEventListener('keydown', (e) => {
    if (!modal.classList.contains('is-open')) return;
    if (e.key === 'Escape') { close(); return; }
    if (e.key === 'ArrowLeft')  { show(current - 1); return; }
    if (e.key === 'ArrowRight') { show(current + 1); return; }

    // Focus trap
    if (e.key === 'Tab') {
      const els = focusable();
      const first = els[0];
      const last  = els[els.length - 1];
      if (e.shiftKey) {
        if (document.activeElement === first) { e.preventDefault(); last.focus(); }
      } else {
        if (document.activeElement === last)  { e.preventDefault(); first.focus(); }
      }
    }
  });
</script>

<style>
  /* Grid */
  .gallery-grid {
    columns: 2;
    column-gap: 0.5rem;
  }
  @media (min-width: 640px) {
    .gallery-grid { columns: 3; column-gap: 0.625rem; }
  }
  @media (min-width: 1024px) {
    .gallery-grid { columns: 4; column-gap: 0.75rem; }
  }

  .gallery-item {
    display: block;
    break-inside: avoid;
    width: 100%;
    padding: 0;
    border: none;
    background: none;
    cursor: pointer;
    margin-bottom: 0.5rem;
    border-radius: 2px;
    overflow: hidden;
    position: relative;
  }
  @media (min-width: 640px) { .gallery-item { margin-bottom: 0.625rem; } }
  @media (min-width: 1024px) { .gallery-item { margin-bottom: 0.75rem; } }

  .gallery-thumb {
    display: block;
    width: 100%;
    height: auto;
    transition: transform 0.25s ease, opacity 0.25s ease;
  }

  .gallery-item:hover .gallery-thumb,
  .gallery-item:focus-visible .gallery-thumb {
    transform: scale(1.03);
    opacity: 0.88;
  }

  .gallery-item:focus-visible {
    outline: 3px solid #F8E71C;
    outline-offset: 2px;
  }

  /* Modal */
  .gallery-modal {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 200;
    align-items: center;
    justify-content: center;
  }
  .gallery-modal.is-open {
    display: flex;
  }

  .gallery-modal-overlay {
    position: absolute;
    inset: 0;
    background: rgba(10, 10, 10, 0.92);
    backdrop-filter: blur(4px);
  }

  .gallery-modal-content {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    max-width: 95vw;
    max-height: 95vh;
  }

  .gallery-img-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .gallery-modal-img {
    max-width: min(85vw, 1200px);
    max-height: 88vh;
    object-fit: contain;
    border-radius: 2px;
    box-shadow: 0 32px 64px rgba(0,0,0,0.6);
  }

  /* Nav buttons */
  .gallery-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    border: 1.5px solid rgba(255,255,255,0.2);
    background: rgba(255,255,255,0.08);
    color: #fff;
    cursor: pointer;
    flex-shrink: 0;
    transition: background 0.15s, border-color 0.15s;
  }
  .gallery-btn:hover {
    background: rgba(255,255,255,0.18);
    border-color: rgba(255,255,255,0.5);
  }
  .gallery-btn:focus-visible {
    outline: 2px solid #F8E71C;
    outline-offset: 2px;
  }

  .gallery-close {
    position: absolute;
    top: -3.5rem;
    right: 0;
    z-index: 2;
  }

  @media (max-width: 639px) {
    .gallery-modal-content { gap: 0.375rem; }
    .gallery-btn { width: 2rem; height: 2rem; }
    .gallery-close { top: -2.75rem; }
  }

  /* Counter */
  .gallery-counter {
    position: absolute;
    bottom: -2.25rem;
    left: 50%;
    transform: translateX(-50%);
    color: rgba(255,255,255,0.5);
    font-size: 0.75rem;
    font-family: var(--font-heading, sans-serif);
    letter-spacing: 0.1em;
    white-space: nowrap;
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .gallery-thumb { transition: none; }
  }
</style>
