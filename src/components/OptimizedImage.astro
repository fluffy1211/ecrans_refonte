---
interface Props {
  src: string;
  alt: string;
  width?: number | string;
  height?: number | string;
  loading?: 'eager' | 'lazy';
  fetchpriority?: 'high' | 'low' | 'auto';
  class?: string;
}

const {
  src,
  alt,
  width,
  height,
  loading = 'lazy',
  fetchpriority,
  class: className,
} = Astro.props;

const webpSrc = src.replace(/\.(jpg|jpeg|png)$/i, '.webp');
---

<picture>
  <source srcset={webpSrc} type="image/webp" />
  <img
    src={src}
    alt={alt}
    width={width}
    height={height}
    loading={loading}
    fetchpriority={fetchpriority}
    class={className}
  />
</picture>
