---
export interface FaqItem {
  q: string;
  a: string;
}

interface Props {
  items: FaqItem[];
}

const { items } = Astro.props;
---

<div class="space-y-3">
  {items.map(({ q, a }) => (
    <details class="group border-2 border-text-main rounded-sm">
      <summary class="flex items-center justify-between gap-4 px-5 py-4 cursor-pointer list-none font-heading font-semibold text-sm text-text-main hover:bg-gray-50 transition-colors duration-150 focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-[-2px] rounded-sm">
        <span>{q}</span>
        <span
          class="flex-shrink-0 w-6 h-6 flex items-center justify-center border-2 border-text-main rounded-full text-text-main font-black text-base leading-none group-open:rotate-45 transition-transform duration-200 select-none"
          aria-hidden="true"
        >+</span>
      </summary>
      <div class="px-5 pb-4 pt-1 font-body text-sm text-gray-600 leading-relaxed border-t border-gray-100">
        {a}
      </div>
    </details>
  ))}
</div>
