---
interface Props {
  text?: string;
  href?: string;
  variant?: 'primary' | 'dark';
  class?: string;
}

const {
  text = 'Réserver le spectacle',
  href = '/contact',
  variant = 'primary',
  class: className = '',
} = Astro.props;

const colorClasses =
  variant === 'dark'
    ? 'bg-text-main text-white focus-visible:outline-white'
    : 'bg-accent text-text-main focus-visible:outline-text-main';
---

<a
  href={href}
  class={`inline-block ${colorClasses} font-heading font-bold text-sm uppercase tracking-widest px-8 py-3 rounded-sm border-2 border-text-main shadow-[4px_4px_0_0_#1C1C1C] hover:shadow-[2px_2px_0_0_#1C1C1C] hover:translate-x-0.5 hover:translate-y-0.5 active:shadow-none active:translate-x-1 active:translate-y-1 hover:opacity-90 active:opacity-75 transition-all duration-150 focus-visible:outline-2 focus-visible:outline-offset-4 ${className}`}
>
  {text}
</a>
